<?xml version="1.0" encoding="utf-8"?>
<!--
    Diagonal gradient used as the welcome screen background.
    Sweeps from a light-blue tint through neutral grey to a soft lavender,
    giving the splash screen a subtle, modern look.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android">
    <gradient
        android:angle="135"
        android:startColor="#E3F2FD"
        android:centerColor="#F5F5F5"
        android:endColor="#EDE7F6"
        android:type="linear" />
</shape>

