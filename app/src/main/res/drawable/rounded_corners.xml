<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <!-- Purple border matching the app's primary colour -->
    <stroke
        android:width="1dp"
        android:color="#6200EE"/>

    <!-- Slightly rounded corners for a soft display appearance -->
    <corners android:radius="8dp" />

    <!-- White fill — overridden programmatically when the calculator is off -->
    <solid android:color="#FFFFFF"/>
</shape>